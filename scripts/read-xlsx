#!/usr/bin/env bash
set -euo pipefail

OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
  Darwin)   OS="darwin" ;;
  Linux)    OS="linux" ;;
  MINGW*|MSYS*|CYGWIN*) OS="windows" ;;
  *)
    echo "read-xlsx: unsupported OS: $OS" >&2
    exit 1
    ;;
esac

case "$ARCH" in
  aarch64) ARCH="arm64" ;;
  x86_64)  ARCH="amd64" ;;
  arm64)   ARCH="arm64" ;;
  *)
    echo "read-xlsx: unsupported architecture: $ARCH" >&2
    exit 1
    ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN="${SCRIPT_DIR}/read-xlsx-${OS}-${ARCH}"
[ "$OS" = "windows" ] && BIN="${BIN}.exe"

if [ ! -f "$BIN" ]; then
  echo "read-xlsx: binary not found: $BIN" >&2
  exit 1
fi

# 実行権限がなければ一時ディレクトリにコピーして権限を付与
if [ ! -x "$BIN" ]; then
  TMP_BIN="${TMPDIR:-/tmp}/read-xlsx-$(id -u)-${OS}-${ARCH}"
  if [ ! -x "$TMP_BIN" ] || ! cmp -s "$BIN" "$TMP_BIN"; then
    cp "$BIN" "$TMP_BIN"
    chmod +x "$TMP_BIN"
  fi
  BIN="$TMP_BIN"
fi

exec "$BIN" "$@"
